{
  "permissions": {
    "allow": [
      "Bash(adb *)",
      "Bash(gradle *)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git merge-base*)",
      "Bash(git ls-tree*)",
      "Bash(git grep*)",
      "Bash(git fetch*)",
      "Bash(git cherry-pick*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git merge*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git worktree*)",
      "Bash(git stash*)",
      "Bash(git rev-list*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(git push origin claude/*)",
      "Bash(jq *)",
      "Bash(kill *)",
      "Bash(nohup adb *)",
      "Bash(/home/user/Android/Sdk/platform-tools/adb *)",
      "Bash(/home/user/gradle-dist/gradle-8.13/bin/gradle *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ],
    "defaultMode": "dontAsk"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_PROJECT_DIR/.claude/hooks/away-mode-prod.sh\"; [ -f \"$f\" ] && sh \"$f\" || exit 0"
          }
        ]
      }
    ]
  }
}
