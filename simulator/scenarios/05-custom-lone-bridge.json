  "params": {
    "msg_per_sec": "1.0",
    "hops_to_live": "8"
  },
  "events": [
    { "kind": "kill-node", "atSec": 30, "nodeIndex": 2 }
  ],
  "assertions": [
    { "kind": "min-total-messages", "min": 100 }
  ]
}
