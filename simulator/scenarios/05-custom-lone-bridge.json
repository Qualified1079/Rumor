    "nodeCount": 5,
    "edges": [
      { "from": 0, "to": 1 },
      { "from": 1, "to": 2, "tags": ["uplink"] },
      { "from": 2, "to": 3, "tags": ["uplink"] },
      { "from": 3, "to": 4 }
